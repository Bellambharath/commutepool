# ============================================================
# CommutePool — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to GitHub.
# ============================================================

# Database (Supabase PostgreSQL + PostGIS)
DATABASE_URL=
DIRECT_URL=

# Google Maps (Places New, Directions, Geocoding, Maps JS)
GOOGLE_MAPS_API_KEY=

# Fast2SMS (OTP SMS delivery)
FAST2SMS_API_KEY=

# Firebase (FCM push notifications ONLY — NOT Firebase Storage)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cloudinary (DL, RC, profile photo storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT (generate long random strings at randomkeygen.com)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# App
NODE_ENV=development
PORT=3000
