# ─── Database ───────────────────────────────────────────
POSTGRES_USER=cp
POSTGRES_PASSWORD=cp
POSTGRES_DB=commutepool
DATABASE_URL=postgres://cp:cp@localhost:5432/commutepool

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Twilio (OTP) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM=+1XXXXXXXXXX

# ─── Test helpers ───────────────────────────────────────
# Set to true in CI / local dev to bypass OTP with code 123456
OTP_BYPASS_IN_TEST=false

# ─── Admin seeding ──────────────────────────────────────
ADMIN_SEED_EMAIL=admin@commutepool.test
ADMIN_SEED_PASSWORD=Admin@1234!

# ─── App ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
