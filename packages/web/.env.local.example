# Local development — point at the API running on your machine
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Production
# NEXT_PUBLIC_API_BASE_URL=https://api.commutepool.pghive.in

# Google Maps JS API key — used client-side ONLY for map rendering on /routes/new.
# Search and routing logic remain server-proxied (packages/api) and never use this key.
# Set this to the same value as the backend's GOOGLE_MAPS_API_KEY for local dev.
# Without this, the map will fail to load (the route cards still work without it).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<your key here>
