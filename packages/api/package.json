{
  "name": "@commutepool/api",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=.env --import tsx src/index.ts",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:init": "prisma migrate dev --name init",
    "db:postgis": "psql $DATABASE_URL -f prisma/postgis.sql",
    "db:generate": "prisma generate",
    "db:seed": "node --env-file=.env --import tsx prisma/seed.ts",
    "db:setup": "npm run db:init && npm run db:postgis && npm run db:generate && npm run db:seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@commutepool/shared": "*",
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "@hono/node-server": "^1.11.1",
    "@hono/zod-validator": "^0.2.2",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "hono": "^4.4.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
